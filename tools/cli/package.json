{
  "name": "@intutic/cli",
  "version": "1.5.0",
  "description": "Intutic CLI — sync daemon, harness detection, and workspace management",
  "type": "module",
  "bin": {
    "intutic": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/intutic/intutic"
  },
  "license": "MIT",
  "homepage": "https://intutic.ai",
  "keywords": [
    "ai",
    "governance",
    "agent",
    "sop",
    "cli"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@intutic/shared-types": "workspace:*",
    "@intutic/id": "workspace:*",
    "@intutic/logger": "workspace:*",
    "@intutic/sync-daemon": "workspace:*",
    "chokidar": "^5.0.0",
    "commander": "^13",
    "ioredis": "^5.11.1",
    "picocolors": "^1"
  },
  "devDependencies": {
    "typescript": "^5.5",
    "tsx": "^4",
    "@types/node": "^22",
    "vitest": "^3"
  }
}
